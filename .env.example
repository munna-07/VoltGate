# Example environment configuration for VoltGate.
# Copy this file to `.env` and uncomment the variables you need.
#
# NOTE: Environment variables are only required when using remote storage options.
# For local file-based storage (default), no environment variables need to be set.

# ------------------------------------------------------------------------------
# Management Web UI
# ------------------------------------------------------------------------------
# MANAGEMENT_PASSWORD=change-me-to-a-strong-password

# ------------------------------------------------------------------------------
# Google OAuth (required to add new Gemini / Antigravity accounts)
# ------------------------------------------------------------------------------
# VOLTGATE_GEMINI_OAUTH_CLIENT_ID=your_google_oauth_client_id
# VOLTGATE_GEMINI_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
# VOLTGATE_ANTIGRAVITY_OAUTH_CLIENT_ID=your_google_oauth_client_id
# VOLTGATE_ANTIGRAVITY_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# ------------------------------------------------------------------------------
# Postgres Token Store (optional)
# ------------------------------------------------------------------------------
# PGSTORE_DSN=postgresql://user:pass@localhost:5432/voltgate
# PGSTORE_SCHEMA=public
# PGSTORE_LOCAL_PATH=/var/lib/voltgate

# ------------------------------------------------------------------------------
# Git-Backed Config Store (optional)
# ------------------------------------------------------------------------------
# GITSTORE_GIT_URL=https://github.com/your-org/voltgate-config.git
# GITSTORE_GIT_USERNAME=git-user
# GITSTORE_GIT_TOKEN=ghp_your_personal_access_token
# GITSTORE_LOCAL_PATH=/data/voltgate/gitstore

# ------------------------------------------------------------------------------
# Object Store Token Store (optional)
# ------------------------------------------------------------------------------
# OBJECTSTORE_ENDPOINT=https://s3.your-cloud.example.com
# OBJECTSTORE_BUCKET=voltgate-config
# OBJECTSTORE_ACCESS_KEY=your_access_key
# OBJECTSTORE_SECRET_KEY=your_secret_key
# OBJECTSTORE_LOCAL_PATH=/data/voltgate/objectstore
